# Docker image tag.
ESPHOME_IMAGE=ghcr.io/esphome/esphome:2026.4

# Local dashboard port.
ESPHOME_PORT=6052

# DEBUG / INFO / WARNING
ESPHOME_LOG_LEVEL=INFO

# Optional: protect the dashboard with basic auth.
ESPHOME_USERNAME=
ESPHOME_PASSWORD=

# Optional: pass proxy settings into the container when font/package downloads are slow.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,10.30.5.0/24
